   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Phase 2 — LSTM Model (Full Samanantar Dataset)\n",
    "\n",
    "### Key changes from Phase 1:\n",
    "- **ChunkedTranslationDataset** with ConcatDataset — handles 10M+ rows without RAM overflow\n",
    "- **Batch size 256**, pin_memory, num_workers=4 for GPU throughput\n",
    "- **Epoch + best checkpointing** with auto-resume on restart\n",
    "- **Full metric suite**: BLEU, ChrF, BERTScore, COMET\n",
    "- DATA_DIR points to Phase2_Preprocessing_NN output"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 1: Imports ───────────────────────────────────────────────────────────\n",
    "import os, gc, math, glob, pickle\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import Dataset, DataLoader, ConcatDataset\n",
    "from tqdm.auto import tqdm"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 2: Config ────────────────────────────────────────────────────────────\n",
    "# CHANGE: DATA_DIR points to chunked preprocessing output (not Kaggle path)\n",
    "DATA_DIR   = './phase2_data/'\n",
    "SAVE_DIR   = './phase2_checkpoints/lstm/'\n",
    "os.makedirs(SAVE_DIR, exist_ok=True)\n",
    "\n",
    "# CHANGE: batch size raised from 64 → 256; lower to 128 if OOM on your GPU\n",
    "BATCH_SIZE    = 256\n",
    "EMBED_DIM     = 300\n",
    "HIDDEN_DIM    = 512\n",
    "DROPOUT       = 0.3\n",
    "LEARNING_RATE = 0.0005\n",
    "N_EPOCHS      = 10\n",
    "CLIP          = 1.0\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"Device: {device}\")\n",
    "if device.type == 'cuda':\n",
    "    print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
    "    print(f\"GPU memory: {torch.cuda.get_device_properties(0).total_memory/1024**3:.1f} GB\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 3: Load vocabs, embeddings, config ───────────────────────────────────\n",
    "with open(os.path.join(DATA_DIR, 'eng_vocab.pkl'), 'rb') as f:\n",
    "    eng_vocab = pickle.load(f)\n",
    "with open(os.path.join(DATA_DIR, 'hi_vocab.pkl'), 'rb') as f:\n",
    "    hi_vocab = pickle.load(f)\n",
    "with open(os.path.join(DATA_DIR, 'preprocessing_config.pkl'), 'rb') as f:\n",
    "    pp_config = pickle.load(f)\n",
    "\n",
    "MAX_LEN    = pp_config['MAX_LEN']\n",
    "eng_matrix = np.load(os.path.join(DATA_DIR, 'eng_embedding_matrix.npy'))\n",
    "hi_matrix  = np.load(os.path.join(DATA_DIR, 'hi_embedding_matrix.npy'))\n",
    "\n",
    "print(f\"English vocab: {len(eng_vocab):,}  |  Matrix: {eng_matrix.shape}\")\n",
    "print(f\"Hindi vocab:   {len(hi_vocab):,}   |  Matrix: {hi_matrix.shape}\")\n",
    "print(f\"MAX_LEN: {MAX_LEN}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 4: Dataset and DataLoaders (same chunked approach as RNN notebook) ───\n",
    "# CHANGE: ChunkedTranslationDataset reads one CSV chunk at a time;\n",
    "# ConcatDataset stitches all chunks into one logical dataset.\n",
    "class ChunkedTranslationDataset(Dataset):\n",
    "    def __init__(self, csv_path, max_len):\n",
    "        df = pd.read_csv(csv_path)\n",
    "        self.english = torch.tensor(\n",
    "            [list(map(int, r.split())) for r in df['eng_padded']], dtype=torch.long)\n",
    "        self.hindi = torch.tensor(\n",
    "            [list(map(int, r.split())) for r in df['hi_padded']], dtype=torch.long)\n",
    "        assert self.english.shape[1] == max_len\n",
    "    def __len__(self): return len(self.english)\n",
    "    def __getitem__(self, idx): return self.english[idx], self.hindi[idx]\n",
    "\n",
    "def make_dataloader(split_name, shuffle):\n",
    "    files    = sorted(glob.glob(os.path.join(DATA_DIR, f'{split_name}_processed_chunk*.csv')))\n",
    "    assert files, f\"No chunks found for '{split_name}'\"\n",
    "    combined = ConcatDataset([ChunkedTranslationDataset(f, MAX_LEN) for f in files])\n",
    "    loader   = DataLoader(combined, batch_size=BATCH_SIZE, shuffle=shuffle,\n",
    "                          pin_memory=(device.type=='cuda'), num_workers=4)\n",
    "    print(f\"  {split_name}: {len(combined):,} pairs | {len(loader):,} batches\")\n",
    "    return loader\n",
    "\n",
    "print(\"Building DataLoaders...\")\n",
    "train_loader = make_dataloader('train', shuffle=True)\n",
    "val_loader   = make_dataloader('val',   shuffle=False)\n",
    "test_loader  = make_dataloader('test',  shuffle=False)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 5: LSTM Encoder (same architecture as Phase 1) ───────────────────────\n",
    "# KEY DIFFERENCE from RNN: LSTM returns (hidden, cell) — both are propagated.\n",
    "class Encoder(nn.Module):\n",
    "    def __init__(self, vocab_size, embed_dim, hidden_dim, dropout, pretrained_embeddings):\n",
    "        super(Encoder, self).__init__()\n",
    "        self.embedding = nn.Embedding(vocab_size, embed_dim)\n",
    "        self.embedding.weight = nn.Parameter(\n",
    "            torch.tensor(pretrained_embeddings, dtype=torch.float32))\n",
    "        self.embedding.weight.requires_grad = True\n",
    "        # LSTM instead of RNN — adds cell state for longer memory\n",
    "        self.lstm = nn.LSTM(input_size=embed_dim, hidden_size=hidden_dim, batch_first=True)\n",
    "        self.attention_q = nn.Linear(hidden_dim, hidden_dim)\n",
    "        self.attention_k = nn.Linear(hidden_dim, hidden_dim)\n",
    "        self.attention_v = nn.Linear(hidden_dim, hidden_dim)\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "        self.scale   = math.sqrt(hidden_dim)\n",
    "\n",
    "    def self_attention(self, hidden_states):\n",
    "        Q = self.attention_q(hidden_states)\n",
    "        K = self.attention_k(hidden_states)\n",
    "        V = self.attention_v(hidden_states)\n",
    "        scores  = torch.bmm(Q, K.transpose(1, 2)) / self.scale\n",
    "        weights = torch.softmax(scores, dim=-1)\n",
    "        weights = self.dropout(weights)\n",
    "        return torch.bmm(weights, V)\n",
    "\n",
    "    def forward(self, src):\n",
    "        embedded = self.dropout(self.embedding(src))\n",
    "        outputs, (hidden, cell) = self.lstm(embedded)\n",
    "        attended = self.self_attention(outputs)\n",
    "        outputs  = outputs + attended   # residual connection\n",
    "        return outputs, hidden, cell    # return cell too\n",
    "\n",
    "print(\"LSTM Encoder defined.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 6: LSTM Decoder (same architecture as Phase 1) ───────────────────────\n",
    "# KEY DIFFERENCE from RNN: takes and returns (hidden, cell) tuple.\n",
    "class Decoder(nn.Module):\n",
    "    def __init__(self, vocab_size, embed_dim, hidden_dim, dropout, pretrained_embeddings):\n",
    "        super(Decoder, self).__init__()\n",
    "        self.embedding = nn.Embedding(vocab_size, embed_dim)\n",
    "        self.embedding.weight = nn.Parameter(\n",
    "            torch.tensor(pretrained_embeddings, dtype=torch.float32))\n",
    "        self.embedding.weight.requires_grad = True\n",
    "        self.attention_q = nn.Linear(hidden_dim, hidden_dim)\n",
    "        self.attention_k = nn.Linear(hidden_dim, hidden_dim)\n",
    "        self.attention_v = nn.Linear(hidden_dim, hidden_dim)\n",
    "        self.lstm    = nn.LSTM(input_size=embed_dim+hidden_dim, hidden_size=hidden_dim, batch_first=True)\n",
    "        self.fc_out  = nn.Linear(hidden_dim, vocab_size)\n",
    "        self.dropout = nn.Dropout(dropout)\n",
    "        self.scale   = math.sqrt(hidden_dim)\n",
    "\n",
    "    def attention(self, decoder_hidden, encoder_outputs):\n",
    "        query = decoder_hidden.permute(1, 0, 2)\n",
    "        Q = self.attention_q(query)\n",
    "        K = self.attention_k(encoder_outputs)\n",
    "        V = self.attention_v(encoder_outputs)\n",
    "        scores  = torch.bmm(Q, K.transpose(1, 2)) / self.scale\n",
    "        weights = torch.softmax(scores, dim=-1)\n",
    "        return torch.bmm(weights, V), weights\n",
    "\n",
    "    def forward(self, tgt, hidden, cell, encoder_outputs):\n",
    "        tgt      = tgt.unsqueeze(1)\n",
    "        embedded = self.dropout(self.embedding(tgt))\n",
    "        context, weights = self.attention(hidden, encoder_outputs)\n",
    "        rnn_input = torch.cat([embedded, context], dim=2)\n",
    "        output, (hidden, cell) = self.lstm(rnn_input, (hidden, cell))\n",
    "        prediction = self.fc_out(output.squeeze(1))\n",
    "        return prediction, hidden, cell, weights\n",
    "\n",
    "print(\"LSTM Decoder defined.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 7: Seq2Seq ────────────────────────────────────────────────────────────\n",
    "class Seq2Seq(nn.Module):\n",
    "    def __init__(self, encoder, decoder, device):\n",
    "        super(Seq2Seq, self).__init__()\n",
    "        self.encoder = encoder\n",
    "        self.decoder = decoder\n",
    "        self.device  = device\n",
    "\n",
    "    def forward(self, src, tgt, teacher_forcing_ratio=0.5):\n",
    "        batch_size     = src.shape[0]\n",
    "        tgt_len        = tgt.shape[1]\n",
    "        tgt_vocab_size = self.decoder.fc_out.out_features\n",
    "        outputs = torch.zeros(batch_size, tgt_len, tgt_vocab_size).to(self.device)\n",
    "        # LSTM encoder returns three values (outputs, hidden, cell)\n",
    "        encoder_outputs, hidden, cell = self.encoder(src)\n",
    "        decoder_input = tgt[:, 0]\n",
    "        for t in range(1, tgt_len):\n",
    "            prediction, hidden, cell, _ = self.decoder(\n",
    "                decoder_input, hidden, cell, encoder_outputs)\n",
    "            outputs[:, t, :] = prediction\n",
    "            use_tf = torch.rand(1).item() < teacher_forcing_ratio\n",
    "            decoder_input = tgt[:, t] if use_tf else prediction.argmax(1)\n",
    "        return outputs\n",
    "\n",
    "print(\"Seq2Seq defined.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 8: Init model, loss, optimiser ──────────────────────────────────────\n",
    "encoder = Encoder(len(eng_vocab), EMBED_DIM, HIDDEN_DIM, DROPOUT, eng_matrix).to(device)\n",
    "decoder = Decoder(len(hi_vocab),  EMBED_DIM, HIDDEN_DIM, DROPOUT, hi_matrix).to(device)\n",
    "model   = Seq2Seq(encoder, decoder, device).to(device)\n",
    "\n",
    "trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "print(f\"Trainable parameters: {trainable:,}\")\n",
    "\n",
    "criterion = nn.CrossEntropyLoss(ignore_index=0)\n",
    "optimizer = optim.Adam(model.parameters(), lr=LEARNING_RATE)\n",
    "scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, 'min', factor=0.5, patience=2)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 9: Train / eval helpers ─────────────────────────────────────────────\n",
    "def train_epoch(model, loader, optimizer, criterion, clip):\n",
    "    model.train(); epoch_loss = 0\n",
    "    for src, tgt in tqdm(loader, desc='Train', leave=False):\n",
    "        src, tgt = src.to(device), tgt.to(device)\n",
    "        optimizer.zero_grad()\n",
    "        output = model(src, tgt, teacher_forcing_ratio=0.5)\n",
    "        output = output[:, 1:, :].reshape(-1, output.shape[-1])\n",
    "        tgt    = tgt[:, 1:].reshape(-1)\n",
    "        loss   = criterion(output, tgt)\n",
    "        loss.backward()\n",
    "        torch.nn.utils.clip_grad_norm_(model.parameters(), clip)\n",
    "        optimizer.step()\n",
    "        epoch_loss += loss.item()\n",
    "    return epoch_loss / len(loader)\n",
    "\n",
    "def evaluate(model, loader, criterion):\n",
    "    model.eval(); epoch_loss = 0\n",
    "    with torch.no_grad():\n",
    "        for src, tgt in tqdm(loader, desc='Val', leave=False):\n",
    "            src, tgt = src.to(device), tgt.to(device)\n",
    "            output   = model(src, tgt, teacher_forcing_ratio=0.0)\n",
    "            output   = output[:, 1:, :].reshape(-1, output.shape[-1])\n",
    "            tgt      = tgt[:, 1:].reshape(-1)\n",
    "            epoch_loss += criterion(output, tgt).item()\n",
    "    return epoch_loss / len(loader)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 10: Training loop with resume support ────────────────────────────────\n",
    "# CHANGE: saves a 'latest' checkpoint every epoch so training can resume\n",
    "# if the AnyDesk session is interrupted.\n",
    "LATEST_CKPT = os.path.join(SAVE_DIR, 'lstm_latest.pt')\n",
    "BEST_CKPT   = os.path.join(SAVE_DIR, 'lstm_best.pt')\n",
    "\n",
    "start_epoch = 0; best_val_loss = float('inf')\n",
    "if os.path.exists(LATEST_CKPT):\n",
    "    ckpt = torch.load(LATEST_CKPT, map_location=device)\n",
    "    model.load_state_dict(ckpt['model'])\n",
    "    optimizer.load_state_dict(ckpt['optimizer'])\n",
    "    scheduler.load_state_dict(ckpt['scheduler'])\n",
    "    start_epoch = ckpt['epoch'] + 1\n",
    "    best_val_loss = ckpt['best_val_loss']\n",
    "    print(f\"Resumed from epoch {ckpt['epoch']} | best_val_loss={best_val_loss:.4f}\")\n",
    "else:\n",
    "    print(\"Starting fresh.\")\n",
    "\n",
    "for epoch in range(start_epoch, N_EPOCHS):\n",
    "    train_loss = train_epoch(model, train_loader, optimizer, criterion, CLIP)\n",
    "    val_loss   = evaluate(model, val_loader, criterion)\n",
    "    scheduler.step(val_loss)\n",
    "    torch.save({'epoch': epoch, 'model': model.state_dict(),\n",
    "                'optimizer': optimizer.state_dict(), 'scheduler': scheduler.state_dict(),\n",
    "                'best_val_loss': best_val_loss}, LATEST_CKPT)\n",
    "    if val_loss < best_val_loss:\n",
    "        best_val_loss = val_loss\n",
    "        torch.save(model.state_dict(), BEST_CKPT)\n",
    "        print(f\"Epoch {epoch+1:02d} | Train: {train_loss:.4f} | Val: {val_loss:.4f}  ✓ saved\")\n",
    "    else:\n",
    "        print(f\"Epoch {epoch+1:02d} | Train: {train_loss:.4f} | Val: {val_loss:.4f}\")\n",
    "print(f\"\\nDone! Best val loss: {best_val_loss:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 11: Inference — build hypothesis and reference lists ─────────────────\n",
    "from sacrebleu.metrics import BLEU, CHRF\n",
    "from bert_score import score as bert_score_fn\n",
    "\n",
    "model.load_state_dict(torch.load(BEST_CKPT, map_location=device))\n",
    "model.eval()\n",
    "\n",
    "idx2hi  = {idx: word for word, idx in hi_vocab.items()}\n",
    "idx2eng = {idx: word for word, idx in eng_vocab.items()}\n",
    "\n",
    "def indices_to_tokens(indices, idx2word):\n",
    "    tokens = []\n",
    "    for idx in indices:\n",
    "        idx = idx.item()\n",
    "        if idx == 2: break\n",
    "        if idx not in [0, 1]: tokens.append(idx2word.get(idx, '<UNK>'))\n",
    "    return tokens\n",
    "\n",
    "all_hypotheses, all_references = [], []\n",
    "for src, tgt in tqdm(test_loader, desc='Test'):\n",
    "    src, tgt = src.to(device), tgt.to(device)\n",
    "    with torch.no_grad():\n",
    "        output = model(src, tgt, teacher_forcing_ratio=0.0)\n",
    "    pred_indices = output.argmax(dim=2)\n",
    "    for i in range(pred_indices.shape[0]):\n",
    "        all_hypotheses.append(' '.join(indices_to_tokens(pred_indices[i], idx2hi)))\n",
    "        all_references.append(' '.join(indices_to_tokens(tgt[i], idx2hi)))\n",
    "print(f\"Inference done. {len(all_hypotheses):,} pairs.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 12: Compute and display all metrics ──────────────────────────────────\n",
    "bleu_score = BLEU().corpus_score(all_hypotheses, [all_references])\n",
    "chrf_score = CHRF().corpus_score(all_hypotheses, [all_references])\n",
    "\n",
    "print(\"Computing BERTScore...\")\n",
    "_, _, F1_bert = bert_score_fn(all_hypotheses, all_references,\n",
    "                               lang='hi', model_type='bert-base-multilingual-cased', verbose=False)\n",
    "bert_f1 = F1_bert.mean().item()\n",
    "\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(\"         LSTM MODEL — PHASE 2 TEST RESULTS\")\n",
    "print(\"=\" * 55)\n",
    "print(f\"  BLEU      : {bleu_score.score:.2f}\")\n",
    "print(f\"  ChrF      : {chrf_score.score:.2f}\")\n",
    "print(f\"  BERTScore : {bert_f1:.4f}\")\n",
    "print(\"=\" * 55)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 13: COMET (optional) ─────────────────────────────────────────────────\n",
    "try:\n",
    "    from comet import download_model, load_from_checkpoint\n",
    "    test_sources = []\n",
    "    for src, _ in test_loader:\n",
    "        for i in range(src.shape[0]):\n",
    "            test_sources.append(' '.join(indices_to_tokens(src[i], idx2eng)))\n",
    "    comet_model = load_from_checkpoint(download_model(\"Unbabel/wmt22-comet-da\"))\n",
    "    comet_data  = [{'src': s, 'mt': h, 'ref': r}\n",
    "                   for s, h, r in zip(test_sources, all_hypotheses, all_references)]\n",
    "    comet_score = comet_model.predict(comet_data, batch_size=64, gpus=1)['system_score']\n",
    "    print(f\"COMET: {comet_score:.4f}\")\n",
    "except Exception as e:\n",
    "    print(f\"COMET skipped: {e}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 14: Sample translations ──────────────────────────────────────────────\n",
    "print(\"SAMPLE TRANSLATIONS\")\n",
    "print(\"=\" * 65)\n",
    "for i in range(5):\n",
    "    print(f\"Hypothesis : {all_hypotheses[i]}\")\n",
    "    print(f\"Reference  : {all_references[i]}\")\n",
    "    print(\"-\" * 65)"
   ]
  }
