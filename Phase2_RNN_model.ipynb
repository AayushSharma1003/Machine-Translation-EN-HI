   "source": [
    "# ── Cell 13: COMET score (optional — needs GPU + ~5 GB download) ──────────────\n",
    "# CHANGE: COMET is a reference-based neural metric that correlates highly with\n",
    "# human judgements. It's heavier than BLEU/ChrF so run this cell only if\n",
    "# the GPU has spare memory after training.\n",
    "# Install: pip install unbabel-comet\n",
    "\n",
    "try:\n",
    "    from comet import download_model, load_from_checkpoint\n",
    "\n",
    "    # Load source sentences from test (needed for COMET)\n",
    "    test_sources = []\n",
    "    for src, tgt in test_loader:\n",
    "        for i in range(src.shape[0]):\n",
    "            src_str = ' '.join(indices_to_tokens(src[i], idx2eng))\n",
    "            test_sources.append(src_str)\n",
    "\n",
    "    comet_model_path = download_model(\"Unbabel/wmt22-comet-da\")\n",
    "    comet_model      = load_from_checkpoint(comet_model_path)\n",
    "\n",
    "    comet_data = [\n",
    "        {'src': s, 'mt': h, 'ref': r}\n",
    "        for s, h, r in zip(test_sources, all_hypotheses, all_references)\n",
    "    ]\n",
    "    comet_output = comet_model.predict(comet_data, batch_size=64, gpus=1)\n",
    "    comet_score  = comet_output['system_score']\n",
    "    print(f\"COMET score: {comet_score:.4f}\")\n",
    "except Exception as e:\n",
    "    print(f\"COMET skipped: {e}\")"
