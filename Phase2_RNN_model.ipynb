   "source": [
    "# ── Cell 1: Imports ───────────────────────────────────────────────────────────\n",
    "import os\n",
    "import gc\n",
    "import math\n",
    "import glob\n",
    "import pickle\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import Dataset, DataLoader, ConcatDataset\n",
    "from tqdm.auto import tqdm"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 2: Config ────────────────────────────────────────────────────────────\n",
    "# CHANGE: DATA_DIR now points to the chunked output from Phase2_Preprocessing_NN.\n",
    "# Update this path to wherever you ran the preprocessing notebook.\n",
    "DATA_DIR   = './phase2_data/'\n",
    "SAVE_DIR   = './phase2_checkpoints/rnn/'\n",
    "os.makedirs(SAVE_DIR, exist_ok=True)\n",
    "\n",
    "# CHANGE: batch size raised from 64 → 256 for GPU efficiency.\n",
    "# If you get CUDA out-of-memory errors, lower to 128 or 64.\n",
    "BATCH_SIZE    = 256\n",
    "EMBED_DIM     = 300\n",
    "HIDDEN_DIM    = 512\n",
    "DROPOUT       = 0.3\n",
    "LEARNING_RATE = 0.0005\n",
    "N_EPOCHS      = 10\n",
    "CLIP          = 1.0\n",
    "\n",
    "# CHANGE: GPU setup — uses CUDA if available (university GPU server).\n",
    "# Also prints GPU name so you can confirm you're on the right device.\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"Device: {device}\")\n",
    "if device.type == 'cuda':\n",
    "    print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
    "    print(f\"GPU memory: {torch.cuda.get_device_properties(0).total_memory/1024**3:.1f} GB\")"
   ]
